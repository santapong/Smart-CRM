# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/smartcrm?schema=public"

# NextAuth
AUTH_SECRET="replace-me-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Email (Resend) — used for outbound email + optional magic-link sign-in
EMAIL_FROM="no-reply@example.com"
RESEND_API_KEY=""
# Signing secret for Resend webhook (svix). Required only if you wire /api/webhooks/resend.
RESEND_WEBHOOK_SECRET=""

# Telegram (shared bot, single-tenant per deployment)
# Create a bot via @BotFather and paste its token here.
TELEGRAM_BOT_TOKEN=""
# Arbitrary string used as the secret_token in setWebhook; we verify the
# `X-Telegram-Bot-Api-Secret-Token` header on inbound updates.
TELEGRAM_WEBHOOK_SECRET=""

# LINE Messaging API (shared channel, single-tenant per deployment)
# From the LINE Developers console -> Messaging API channel.
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_CHANNEL_SECRET=""

# App
NEXT_PUBLIC_APP_NAME="Smart CRM"
