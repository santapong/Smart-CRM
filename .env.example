# ────────────────────────────────────────────────────────────────────────────
# Database
# ────────────────────────────────────────────────────────────────────────────
# Local dev: point at the Postgres started by `docker compose up -d`.
# Vercel / production: use a POOLED connection string (PgBouncer transaction
# mode) from your Postgres provider — Neon, Supabase, Vercel Postgres, etc.
# Each Vercel serverless invocation opens a new connection, so a non-pooled
# direct URL will exhaust the database under load.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/smartcrm?schema=public"

# Direct (non-pooled) URL, used only by `prisma migrate` / `prisma db push`.
# Optional locally — when unset, Prisma falls back to DATABASE_URL.
# Required when DATABASE_URL points at a transaction-mode pooler that doesn't
# support the prepared statements migrations rely on.
DIRECT_URL=""

# ────────────────────────────────────────────────────────────────────────────
# NextAuth (v5)
# ────────────────────────────────────────────────────────────────────────────
# Generate with: `openssl rand -base64 32`
AUTH_SECRET="replace-me-with-openssl-rand-base64-32"

# Local: full URL with port. On Vercel native deployments this is auto-set;
# you can leave it blank in the Vercel dashboard.
AUTH_URL="http://localhost:3000"

# Set to `true` when deploying behind a proxy/CDN (Vercel preview URLs,
# custom domains, etc.) so NextAuth trusts the Host header. Required on
# Vercel for non-production deploys to log in.
AUTH_TRUST_HOST="true"

# ────────────────────────────────────────────────────────────────────────────
# Email (optional)
# ────────────────────────────────────────────────────────────────────────────
EMAIL_FROM="no-reply@example.com"
RESEND_API_KEY=""

# ────────────────────────────────────────────────────────────────────────────
# App
# ────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Smart CRM"
