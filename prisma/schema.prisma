generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth (NextAuth Prisma adapter) ----------

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime     @default(now())

  accounts           Account[]
  sessions           Session[]
  memberships        Membership[]
  ownedDeals         Deal[]               @relation("DealOwner")
  activities         Activity[]           @relation("ActivityOwner")
  accountAssignments AccountAssignment[]
  assignedTickets    Ticket[]             @relation("TicketAssignee")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Tenancy ----------

enum Role {
  OWNER
  ADMIN
  MEMBER
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  memberships            Membership[]
  companies              Company[]
  contacts               Contact[]
  deals                  Deal[]
  activities             Activity[]
  stages                 PipelineStage[]
  tags                   Tag[]
  accountAssignments     AccountAssignment[]
  slaPolicies            SlaPolicy[]
  tickets                Ticket[]
  customFieldDefinitions CustomFieldDefinition[]
  customFieldValues      CustomFieldValue[]
}

model Membership {
  id     String @id @default(cuid())
  userId String
  orgId  String
  role   Role   @default(MEMBER)

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, orgId])
  @@index([orgId])
}

// ---------- CRM domain ----------

// AccountTier drives SLA defaults, default workflows, and reporting cuts.
// The UI labels the entity "Account" but the Prisma model stays `Company`
// to avoid clashing with the NextAuth OAuth `Account` model.
enum AccountTier {
  SMB
  MID_MARKET
  ENTERPRISE
  STRATEGIC
}

model Company {
  id              String       @id @default(cuid())
  orgId           String
  name            String
  domain          String?
  industry        String?
  size            String?
  notes           String?      @db.Text
  tier            AccountTier  @default(SMB)
  parentCompanyId String?
  arr             Decimal?     @db.Decimal(14, 2)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  org               Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parent            Company?            @relation("CompanyHierarchy", fields: [parentCompanyId], references: [id], onDelete: SetNull)
  children          Company[]           @relation("CompanyHierarchy")
  contacts          Contact[]
  deals             Deal[]
  activities        Activity[]
  team              AccountAssignment[]
  tickets           Ticket[]
  customFieldValues CustomFieldValue[]

  @@index([orgId, name])
  @@index([orgId, tier])
  @@index([orgId, parentCompanyId])
}

enum DecisionRole {
  CHAMPION
  ECONOMIC_BUYER
  USER
  INFLUENCER
  BLOCKER
}

model Contact {
  id           String        @id @default(cuid())
  orgId        String
  companyId    String?
  firstName    String
  lastName     String
  email        String?
  phone        String?
  title        String?
  notes        String?       @db.Text
  isPrimary    Boolean       @default(false)
  decisionRole DecisionRole?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  org               Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  company           Company?           @relation(fields: [companyId], references: [id], onDelete: SetNull)
  tags              ContactTag[]
  deals             Deal[]
  activities        Activity[]
  tickets           Ticket[]
  customFieldValues CustomFieldValue[]

  @@index([orgId, lastName])
  @@index([orgId, email])
  @@index([orgId, companyId, isPrimary])
}

model Tag {
  id    String @id @default(cuid())
  orgId String
  name  String
  color String @default("#64748b")

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contacts ContactTag[]

  @@unique([orgId, name])
}

model ContactTag {
  contactId String
  tagId     String

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
}

model PipelineStage {
  id    String @id @default(cuid())
  orgId String
  name  String
  order Int
  color String @default("#3b82f6")

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deals Deal[]

  @@unique([orgId, name])
  @@index([orgId, order])
}

enum DealStatus {
  OPEN
  WON
  LOST
}

model Deal {
  id        String     @id @default(cuid())
  orgId     String
  title     String
  value     Decimal    @default(0) @db.Decimal(12, 2)
  currency  String     @default("USD")
  status    DealStatus @default(OPEN)
  stageId   String
  companyId String?
  contactId String?
  ownerId   String?
  closeDate DateTime?
  notes     String?    @db.Text
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  org               Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  stage             PipelineStage      @relation(fields: [stageId], references: [id])
  company           Company?           @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact           Contact?           @relation(fields: [contactId], references: [id], onDelete: SetNull)
  owner             User?              @relation("DealOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  activities        Activity[]
  customFieldValues CustomFieldValue[]

  @@index([orgId, stageId])
  @@index([orgId, status])
}

enum ActivityType {
  TASK
  CALL
  MEETING
  NOTE
}

model Activity {
  id          String       @id @default(cuid())
  orgId       String
  type        ActivityType @default(TASK)
  title       String
  body        String?      @db.Text
  dueAt       DateTime?
  completedAt DateTime?
  companyId   String?
  contactId   String?
  dealId      String?
  ownerId     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  company Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  deal    Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  owner   User?        @relation("ActivityOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([orgId, dueAt])
  @@index([orgId, completedAt])
  @@index([orgId, companyId])
}

// ---------- Enterprise: account team, SLA, tickets, custom fields ----------

enum AccountTeamRole {
  OWNER
  AE
  SE
  CSM
  EXEC_SPONSOR
}

model AccountAssignment {
  id        String          @id @default(cuid())
  orgId     String
  companyId String
  userId    String
  role      AccountTeamRole
  createdAt DateTime        @default(now())

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  company Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId, role])
  @@index([orgId, companyId])
  @@index([orgId, userId])
}

// SlaPolicy is per (org, tier): for example STRATEGIC gets 60min first response,
// ENTERPRISE 4h, MID_MARKET 24h, SMB 72h. Breach is computed on read from
// Ticket.createdAt + firstResponseMinutes vs Ticket.firstResponseAt (or now()).
model SlaPolicy {
  id                   String      @id @default(cuid())
  orgId                String
  tier                 AccountTier
  firstResponseMinutes Int
  resolutionMinutes    Int
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, tier])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Ticket {
  id              String         @id @default(cuid())
  orgId           String
  companyId       String
  contactId       String?
  assigneeId      String?
  subject         String
  body            String?        @db.Text
  status          TicketStatus   @default(OPEN)
  priority        TicketPriority @default(NORMAL)
  firstResponseAt DateTime?
  resolvedAt      DateTime?
  closedAt        DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  company  Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact  Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assignee User?        @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([orgId, companyId])
  @@index([orgId, status])
  @@index([orgId, assigneeId])
  @@index([orgId, createdAt])
}

// Custom fields let each org store its own data on Company/Contact/Deal
// without per-tenant schema migrations. The value table is typed-by-column —
// CustomFieldDefinition.type tells callers which value* column to read.
enum CustomFieldEntity {
  COMPANY
  CONTACT
  DEAL
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  BOOLEAN
  SELECT
  URL
}

model CustomFieldDefinition {
  id        String            @id @default(cuid())
  orgId     String
  entity    CustomFieldEntity
  key       String
  label     String
  type      CustomFieldType
  options   Json?
  required  Boolean           @default(false)
  order     Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  org    Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  values CustomFieldValue[]

  @@unique([orgId, entity, key])
  @@index([orgId, entity, order])
}

model CustomFieldValue {
  id           String    @id @default(cuid())
  orgId        String
  definitionId String
  companyId    String?
  contactId    String?
  dealId       String?
  valueText    String?   @db.Text
  valueNumber  Decimal?  @db.Decimal(20, 6)
  valueDate    DateTime?
  valueBoolean Boolean?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  org        Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  definition CustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  company    Company?              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact    Contact?              @relation(fields: [contactId], references: [id], onDelete: Cascade)
  deal       Deal?                 @relation(fields: [dealId], references: [id], onDelete: Cascade)

  // At most one value per (definition, target). The three nullable pairs
  // model "one of company / contact / deal" without polymorphism.
  @@unique([definitionId, companyId])
  @@unique([definitionId, contactId])
  @@unique([definitionId, dealId])
  @@index([orgId, definitionId])
  @@index([orgId, companyId])
  @@index([orgId, contactId])
  @@index([orgId, dealId])
}
